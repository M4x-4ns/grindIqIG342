# GrindIQ — Environment Variables Template
# Copy this file to .env.local for local development
# Never commit .env.local / .env.staging / .env.production

# App environment identifier
VITE_APP_ENV=local

# Backend API base URL
VITE_API_BASE_URL=http://localhost:3001

# ESP32 sensor base URL (Local network IP of your ESP32)
VITE_ESP32_BASE_URL=http://192.168.1.100

# Sensor polling interval in milliseconds (default: 30000 = 30s)
VITE_SENSOR_POLL_INTERVAL=30000

# Bypass real sensor in development (returns mock data)
# Set to true to develop without an ESP32 connected
VITE_DEV_SENSOR_BYPASS=false
